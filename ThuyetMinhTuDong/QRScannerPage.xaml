<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ThuyetMinhTuDong.QRScannerPage"
             BackgroundColor="#0F0F0F"
             Title="Quét mã QR">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label 
            Text="Quét mã QR"
            TextColor="#D4AF37"
            FontSize="24"
            FontAttributes="Bold"
            HorizontalOptions="Center"/>

        <Label 
            Text="Nhập giá trị QR code:"
            TextColor="White"
            FontSize="14"/>

        <Border Padding="0" Stroke="#B71C1C" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>
            <Entry 
                x:Name="QRInputEntry"
                Placeholder="Nhập mã QR hoặc quét..."
                PlaceholderColor="#A0938A"
                TextColor="White"
                BackgroundColor="#1A1111"
                Margin="10"/>
        </Border>

        <Label 
            x:Name="ResultLabel"
            Text=""
            TextColor="#D4AF37"
            FontSize="13"
            HorizontalOptions="Center"/>

        <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,20,0,0">
            <Button 
                Grid.Column="0"
                Text="Quay lại"
                TextColor="White"
                BackgroundColor="#B71C1C"
                CornerRadius="8"
                Clicked="OnCancelClicked"/>

            <Button 
                Grid.Column="1"
                x:Name="ConfirmButton"
                Text="Xác nhận"
                TextColor="White"
                BackgroundColor="#B71C1C"
                CornerRadius="8"
                Clicked="OnConfirmClicked"/>
        </Grid>
    </VerticalStackLayout>

</ContentPage>


