<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="ThuyetMinhTuDong.MainPage"
             BackgroundColor="#0F0F0F">

    <Grid>
        <!-- MAP PLACEHOLDER (Top Area) -->
        <maps:Map x:Name="MyMap" IsShowingUser="False" MapType="Street" VerticalOptions="Fill" HorizontalOptions="Fill" />

        <!-- LỚP ĐÈ LÊN TRÊN: Bottom panel -->
        <VerticalStackLayout VerticalOptions="End" 
                             Padding="15,10,15,30" 
                             Spacing="20" 
                             BackgroundColor="#0F0F0F">
            <VerticalStackLayout.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Up" Swiped="OnSwipeUp" />
                <SwipeGestureRecognizer Direction="Down" Swiped="OnSwipeDown" />
            </VerticalStackLayout.GestureRecognizers>
            
            <!-- Swipe Handle -->
            <BoxView HeightRequest="4" WidthRequest="40" Color="#B71C1C" CornerRadius="2" HorizontalOptions="Center" Margin="0,0,0,5" />

            <!-- Header Row: Language Button & Settings -->
            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                <Button Grid.Column="0" x:Name="LanguageButton" Text="VN Vietnamese ▾" TextColor="White" FontAttributes="Bold" FontSize="13" BackgroundColor="Transparent" Padding="15,8" CornerRadius="16" BorderColor="#B71C1C" BorderWidth="1" HorizontalOptions="Start" Clicked="OnAddLanguageClicked" />
                <Button Grid.Column="1" Text="⚙" TextColor="#D4AF37" FontSize="18" BackgroundColor="Transparent" Padding="10" CornerRadius="16" BorderColor="#B71C1C" BorderWidth="1" />
            </Grid>

            <VerticalStackLayout x:Name="ExpandableContent" Spacing="25" HeightRequest="0" Opacity="0" IsVisible="True">
                <!-- Tabs -->
                <Grid ColumnDefinitions="*, *, *">
                    <VerticalStackLayout Grid.Column="0" Spacing="8">
                        <Label Text="Giới thiệu" TextColor="#D4AF37" HorizontalOptions="Center" FontSize="14" FontAttributes="Bold"/>
                        <BoxView HeightRequest="2" Color="#B71C1C" HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <Label Text="Gần bạn" TextColor="#A0938A" HorizontalOptions="Center" FontSize="14" FontAttributes="Bold"/>
                        <BoxView HeightRequest="2" Color="#3A2121" HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2" Spacing="8">
                        <Label Text="Yêu thích" TextColor="#A0938A" HorizontalOptions="Center" FontSize="14" FontAttributes="Bold"/>
                        <BoxView HeightRequest="2" Color="#3A2121" HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Media Player Card -->
                <Border BackgroundColor="#1A1111" Stroke="#B71C1C" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <!-- Status -->
                        <HorizontalStackLayout Spacing="8" Margin="0,0,0,5">
                            <Label Text="▶" TextColor="#D4AF37" FontSize="12" VerticalOptions="Center"/>
                            <Label Text="Đang phát · Bún bò Huế Cô Ba" TextColor="#D4AF37" FontSize="12" FontAttributes="Bold" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Label Text="Bún bò Huế Cô Ba" TextColor="White" FontAttributes="Bold" FontSize="20"/>

                        <Label Text="Quán bún bò nổi tiếng hơn 30 năm tại phố Nguyễn Công Trứ. Nước dùng được ninh từ xương heo và sả, tạo nên hương vị đậm đà đặc trưng miền Trung" 
                               TextColor="#A0938A" FontSize="13" LineHeight="1.5" LineBreakMode="WordWrap" Margin="0,5,0,10"/>

                        <!-- Waveform placeholder -->
                        <HorizontalStackLayout Spacing="3" HeightRequest="30" HorizontalOptions="Start">
                            <BoxView WidthRequest="4" HeightRequest="15" Color="#D4AF37" VerticalOptions="Center" CornerRadius="2"/>
                            <BoxView WidthRequest="4" HeightRequest="25" Color="#D4AF37" VerticalOptions="Center" CornerRadius="2"/>
                            <BoxView WidthRequest="4" HeightRequest="10" Color="#D4AF37" VerticalOptions="Center" CornerRadius="2"/>
                            <BoxView WidthRequest="4" HeightRequest="30" Color="#D4AF37" VerticalOptions="Center" CornerRadius="2"/>
                            <BoxView WidthRequest="4" HeightRequest="20" Color="#D4AF37" VerticalOptions="Center" CornerRadius="2"/>
                            <BoxView WidthRequest="4" HeightRequest="15" Color="#D4AF37" VerticalOptions="Center" CornerRadius="2"/>
                            <BoxView WidthRequest="4" HeightRequest="28" Color="#D4AF37" VerticalOptions="Center" CornerRadius="2"/>
                            <BoxView WidthRequest="4" HeightRequest="8" Color="#D4AF37" VerticalOptions="Center" CornerRadius="2"/>
                            <BoxView WidthRequest="4" HeightRequest="22" Color="#D4AF37" VerticalOptions="Center" CornerRadius="2"/>
                            <BoxView WidthRequest="4" HeightRequest="16" Color="#D4AF37" VerticalOptions="Center" CornerRadius="2"/>

                            <!-- Unplayed part -->
                            <BoxView WidthRequest="4" HeightRequest="25" Color="#3A2121" VerticalOptions="Center" CornerRadius="2"/>
                            <BoxView WidthRequest="4" HeightRequest="12" Color="#3A2121" VerticalOptions="Center" CornerRadius="2"/>
                            <BoxView WidthRequest="4" HeightRequest="18" Color="#3A2121" VerticalOptions="Center" CornerRadius="2"/>
                            <BoxView WidthRequest="4" HeightRequest="8" Color="#3A2121" VerticalOptions="Center" CornerRadius="2"/>
                        </HorizontalStackLayout>

                        <!-- Progress bar -->
                        <Grid ColumnDefinitions="*,*" Margin="0,15,0,0">
                            <BoxView Grid.Column="0" Grid.ColumnSpan="2" HeightRequest="4" Color="#3A2121" VerticalOptions="Center" CornerRadius="2"/>
                            <BoxView Grid.Column="0" HeightRequest="4" Color="#B71C1C" VerticalOptions="Center" CornerRadius="2"/>
                        </Grid>

                        <!-- Controls -->
                        <Grid ColumnDefinitions="Auto, Auto, Auto, *, Auto, Auto" Margin="0,20,0,0" VerticalOptions="Center">
                            <Border Grid.Column="0" BackgroundColor="Transparent" Stroke="#D4AF37" Padding="12,8" Margin="0,0,10,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="⏪" TextColor="White" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Border Grid.Column="1" BackgroundColor="Transparent" Stroke="#D4AF37" Padding="12,8" Margin="0,0,10,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <!-- Pause icon approx -->
                                <HorizontalStackLayout Spacing="3" HorizontalOptions="Center" VerticalOptions="Center">
                                    <BoxView WidthRequest="4" HeightRequest="14" Color="White"/>
                                    <BoxView WidthRequest="4" HeightRequest="14" Color="White"/>
                                </HorizontalStackLayout>
                            </Border>
                            <Border Grid.Column="2" BackgroundColor="Transparent" Stroke="#D4AF37" Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="⏩" TextColor="White" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>

                            <Label Grid.Column="4" Text="TTS" TextColor="#A0938A" VerticalOptions="Center" Margin="0,0,8,0" FontSize="13" FontAttributes="Bold"/>
                            <Switch Grid.Column="5" IsToggled="True" OnColor="#B71C1C" ThumbColor="White" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </Grid>

</ContentPage>
