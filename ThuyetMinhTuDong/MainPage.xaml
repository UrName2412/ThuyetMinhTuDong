<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="ThuyetMinhTuDong.MainPage"
             BackgroundColor="#0F0F0F">

    <Grid>
        <!-- Bản đồ (Phần trên) -->
        <maps:Map x:Name="MyMap" IsShowingUser="False" MapType="Street" VerticalOptions="Fill" HorizontalOptions="Fill" />

        <!-- Thẻ tọa độ người dùng -->
        <Border x:Name="CoordBorder"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="15,50,15,0"
                Padding="10,8"
                BackgroundColor="#CC1A1111"
                Stroke="#B71C1C"
                ZIndex="20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10"/>
            </Border.StrokeShape>
            <VerticalStackLayout>
                <Label x:Name="UserCoordinatesLabel"
                       Text="📍 Lat: --\nLng: --"
                       TextColor="White"
                       FontSize="12"
                       LineBreakMode="WordWrap"/>
                <!-- Thẻ tạm thời để kiểm tra Trigger -->
                <Label x:Name="DebugTriggerLabel"
                       Text="Chưa vào vùng"
                       TextColor="Yellow"
                       FontSize="11"
                       FontAttributes="Bold"
                       Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Border>

        <!-- LỚP ĐÈ LÊN TRÊN: Khung phía dưới -->
        <VerticalStackLayout VerticalOptions="End" 
                             Padding="15,10,15,30" 
                             Spacing="20" 
                             BackgroundColor="#0F0F0F">
            <VerticalStackLayout.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Up" Swiped="OnSwipeUp" />
                <SwipeGestureRecognizer Direction="Down" Swiped="OnSwipeDown" />
            </VerticalStackLayout.GestureRecognizers>

            <!-- Thanh trượt -->
            <BoxView HeightRequest="4" WidthRequest="40" Color="#B71C1C" CornerRadius="2" HorizontalOptions="Center" Margin="0,0,0,5" />

            <!-- Thanh công cụ: Ngôn ngữ & GPS -->
            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                <Button Grid.Column="0" x:Name="LanguageButton" Text="Tiếng Việt ▾" TextColor="White" FontAttributes="Bold" FontSize="13" BackgroundColor="Transparent" Padding="15,8" CornerRadius="16" BorderColor="#B71C1C" BorderWidth="1" HorizontalOptions="Start" Clicked="OnAddLanguageClicked" />
                <Button Grid.Column="1" x:Name="GpsToggleButton" Text="GPS: OFF" TextColor="#D4AF37" FontSize="13" FontAttributes="Bold" BackgroundColor="Transparent" Padding="10" CornerRadius="16" BorderColor="#B71C1C" BorderWidth="1" />
            </Grid>

            <VerticalStackLayout x:Name="ExpandableContent" Spacing="25" HeightRequest="0" Opacity="0" IsVisible="True">
                <!-- Các Tab -->
                <Grid ColumnDefinitions="*, *">
                    <VerticalStackLayout Grid.Column="0" Spacing="8" x:Name="Tab1Header">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTab1Tapped" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label x:Name="LblTab1" Text="Giới thiệu" TextColor="#D4AF37" HorizontalOptions="Center" FontSize="14" FontAttributes="Bold"/>
                        <BoxView x:Name="LineTab1" HeightRequest="2" Color="#B71C1C" HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="8" x:Name="Tab2Header">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTab2Tapped" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label x:Name="LblTab2" Text="Gần bạn" TextColor="#A0938A" HorizontalOptions="Center" FontSize="14" FontAttributes="Bold"/>
                        <BoxView x:Name="LineTab2" HeightRequest="2" Color="#3A2121" HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Thẻ Trình phát Media (Nội dung Tab 1) -->
                <Border x:Name="Tab1Content" IsVisible="True" BackgroundColor="#1A1111" Stroke="#B71C1C" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <!-- Trạng thái -->
                        <HorizontalStackLayout Spacing="8" Margin="0,0,0,5">
                            <Label Text="▶" TextColor="#D4AF37" FontSize="12" VerticalOptions="Center"/>
                            <Label Text="Chưa chọn địa điểm" TextColor="#D4AF37" FontSize="12" FontAttributes="Bold" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Label Text="Chọn một địa điểm" TextColor="White" FontAttributes="Bold" FontSize="20"/>

                        <ScrollView HeightRequest="90" Margin="0,5,0,5">
                            <Label x:Name="DescriptionLabel" Text="Vui lòng chọn một địa điểm để xem thông tin chi tiết." 
                                   TextColor="#A0938A" FontSize="13" LineHeight="1.5" LineBreakMode="WordWrap" />
                        </ScrollView>

                        <!-- Danh sách ảnh để bên ngoài ScrollView để không bị cắt -->
                        <CollectionView ItemsSource="{Binding PoiImages}" HeightRequest="130" Margin="0,0,0,5">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Stroke="#B71C1C" StrokeThickness="1" BackgroundColor="#111111" Padding="0" HeightRequest="130" WidthRequest="190">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPoiImageTapped" />
                                        </Border.GestureRecognizers>
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFit" HeightRequest="130" WidthRequest="190" BackgroundColor="#111111" />
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Các nút điều khiển -->
                        <Grid ColumnDefinitions="Auto, *, Auto, Auto" Margin="0,20,0,0" VerticalOptions="Center">
                            <Border Grid.Column="0"
                                    BackgroundColor="Transparent"
                                    Stroke="#D4AF37"
                                    WidthRequest="42"
                                    HeightRequest="42"
                                    Padding="0"
                                    Margin="0,0,10,0"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPlayPauseTapped" />
                                </Border.GestureRecognizers>
                                <Label x:Name="PlayPauseIcon"
                                       Text="&#xF04B;"
                                       FontFamily="FontAwesomeSolid"
                                       TextColor="White"
                                       FontSize="16"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       HorizontalOptions="Fill"
                                       VerticalOptions="Fill"/>
                            </Border>

                            <Label Grid.Column="2" Text="TTS" TextColor="#A0938A" VerticalOptions="Center" Margin="0,0,8,0" FontSize="13" FontAttributes="Bold"/>
                            <Switch x:Name="TtsSwitch" Grid.Column="3" IsToggled="True" OnColor="#B71C1C" ThumbColor="White" VerticalOptions="Center"/>
                        </Grid>

                        <!-- Nút mở Google Maps -->
                        <Button x:Name="OpenMapButton" 
                                Text="Mở bản đồ" 
                                BackgroundColor="#B71C1C" 
                                TextColor="White" 
                                CornerRadius="8" 
                                FontAttributes="Bold" 
                                FontSize="14" 
                                Margin="0,10,0,0"
                                Clicked="OnOpenMapClicked"
                                IsVisible="{Binding IsMapLinkVisible}"/>

                    </VerticalStackLayout>
                </Border>

                <!-- Nội dung Tab 2 -->
                <VerticalStackLayout x:Name="Tab2Content" IsVisible="False" Spacing="10">
                    <Label Text="Các địa điểm gần bạn" TextColor="White" FontSize="16" FontAttributes="Bold" HorizontalOptions="Start" Margin="0,10,0,0"/>
                    <ScrollView Margin="0,5,0,0" HeightRequest="250">
                        <VerticalStackLayout x:Name="NearbyPlacesList" Spacing="10">
                            <!-- Các mục sẽ được tải từ code -->
                            <Label x:Name="EmptyNearbyLabel" Text="Hiện tại không có mục nào để hiển thị." TextColor="#A0938A" FontSize="14" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </VerticalStackLayout>

        <!-- Overlay xem ảnh phóng to -->
        <Grid x:Name="ImagePreviewOverlay" IsVisible="False" BackgroundColor="#CC000000" InputTransparent="False" ZIndex="100">
            <BoxView x:Name="ImagePreviewBackdrop" BackgroundColor="Transparent" />

            <Grid RowDefinitions="Auto,*" Padding="12,40,12,20" RowSpacing="16">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <Label Text="Xem ảnh" TextColor="White" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                    <Button x:Name="CloseImagePreviewButton" Grid.Column="1" Text="✕" TextColor="White" BackgroundColor="#333333" WidthRequest="42" HeightRequest="42" CornerRadius="21" />
                </Grid>

                <CarouselView x:Name="PreviewCarousel" Grid.Row="1" ItemsSource="{Binding PoiImages}">
                    <CarouselView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Image Source="{Binding ImageUrl}" Aspect="AspectFit" HorizontalOptions="Fill" VerticalOptions="Fill" />
                            </Grid>
                        </DataTemplate>
                    </CarouselView.ItemTemplate>
                </CarouselView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
