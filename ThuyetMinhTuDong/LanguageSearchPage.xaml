<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ThuyetMinhTuDong.LanguageSearchPage"
             Title="Chọn ngôn ngữ"
             BackgroundColor="#0F0F0F">

    <Grid RowDefinitions="Auto,Auto,*" Padding="15">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
            <Label Text="Chọn ngôn ngữ TTS" TextColor="White" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
            <Button Grid.Column="1" Text="✕" TextColor="#D4AF37" FontSize="18" BackgroundColor="Transparent" Padding="10" CornerRadius="16" BorderColor="#B71C1C" BorderWidth="1" Clicked="OnCloseClicked" />
        </Grid>

        <!-- Search Bar -->
        <SearchBar Grid.Row="1"
                   x:Name="SearchLanguageBar"
                   Placeholder="Tìm kiếm ngôn ngữ..."
                   TextColor="White"
                   PlaceholderColor="#A0938A"
                   CancelButtonColor="#D4AF37"
                   BackgroundColor="#1A1111"
                   TextChanged="OnSearchTextChanged"
                   Margin="0,0,0,15" />
        
        <!-- Languages List -->
        <CollectionView Grid.Row="2"
                        x:Name="LanguagesList"
                        SelectionMode="Single"
                        SelectionChanged="OnLanguageSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="15" Margin="0,5,0,5" 
                            BackgroundColor="#1A1111" 
                            Stroke="#B71C1C"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Label Text="{Binding .}" 
                               TextColor="White" 
                               FontSize="16"
                               Padding="5" />
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
